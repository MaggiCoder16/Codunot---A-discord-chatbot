# ─── Required ─────────────────────────────────────────────────────────────────
# Without these the bot will not start.

DISCORD_TOKEN=
GROQ_API_KEY=

# ─── Optional (feature-based) ────────────────────────────────────────────────
# Leave blank or remove lines you don't need. Features that depend on a missing
# key will be silently disabled or will show a user-friendly error.

# Image / video / transcription via deAPI.ai
DEAPI_API_KEY=
DEAPI_WEBHOOK_URL=
DEAPI_RESULT_BASE=
DEAPI_VID2TXT_WEBHOOK_URL=
DEAPI_VID2TXT_BASE_URL=

# Image generation (test_api.py)
TEST_API_KEY=

# Hugging Face image generation
HUGGINGFACE_API_KEY_IMAGE_GEN=

# Replicate
REPLICATE_API_TOKEN=

# Google AI Studio / Gemini
GEMINI_API_KEY=

# top.gg vote integration
TOPGG_TOKEN=
TOPGG_WEBHOOK_AUTH=

# Lavalink music server (leave LAVALINK_HOST blank to use yt-dlp fallback)
LAVALINK_HOST=
LAVALINK_PORT=443
LAVALINK_PASSWORD=
LAVALINK_SECURE=true

# yt-dlp cookies (helps bypass age-gated / rate-limited content)
# Paste full Netscape cookie-jar content here, or set YTDL_COOKIES_TXT to a file path.
YTDL_COOKIE_CONTENT=
